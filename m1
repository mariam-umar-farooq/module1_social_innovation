<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Module 1 Activities — Understanding Social Challenges</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #F7F4EF;
    --surface: #FFFFFF;
    --ink: #1A1A1A;
    --ink-light: #6B6560;
    --accent: #2D6A4F;
    --accent-light: #D8F3DC;
    --border: #E2DDD8;
    --amber: #D4870A;
    --amber-light: #FFF3CD;
    --warn: #E07A5F;
    --warn-light: #FDE8E3;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    font-family: 'DM Sans', sans-serif;
    color: var(--ink);
    min-height: 100vh;
    padding: 0;
  }

  /* ── NAV TABS ── */
  .tab-nav {
    display: flex;
    background: var(--surface);
    border-bottom: 2px solid var(--border);
    overflow-x: auto;
    scrollbar-width: none;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .tab-nav::-webkit-scrollbar { display: none; }

  .tab-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 14px 18px;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--ink-light);
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .tab-btn:hover { color: var(--accent); }

  .tab-btn.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .tab-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--border);
    flex-shrink: 0;
    transition: background 0.2s;
  }

  .tab-btn.done .tab-dot { background: var(--accent); }
  .tab-btn.active .tab-dot { background: var(--accent); }

  /* ── PANELS ── */
  .panel { display: none; padding: 32px 24px 60px; max-width: 680px; margin: 0 auto; }
  .panel.active { display: block; animation: fadeUp 0.4s ease both; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── PANEL HEADER ── */
  .panel-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-light);
    padding: 4px 10px;
    border-radius: 4px;
    margin-bottom: 14px;
  }

  .panel h2 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(22px, 4vw, 32px);
    line-height: 1.2;
    margin-bottom: 10px;
  }

  .panel-intro {
    font-size: 14px;
    color: var(--ink-light);
    line-height: 1.65;
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }

  .time-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-light);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 99px;
    padding: 3px 10px;
    margin-bottom: 20px;
  }

  /* ── QUESTION BLOCKS ── */
  .q-block {
    margin-bottom: 24px;
    animation: fadeUp 0.4s ease both;
  }

  .q-block:nth-child(1) { animation-delay: 0.05s; }
  .q-block:nth-child(2) { animation-delay: 0.10s; }
  .q-block:nth-child(3) { animation-delay: 0.15s; }
  .q-block:nth-child(4) { animation-delay: 0.20s; }

  .q-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
    line-height: 1.4;
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }

  .q-label .q-icon {
    font-size: 15px;
    margin-top: 1px;
    flex-shrink: 0;
  }

  .q-hint {
    font-size: 12px;
    color: var(--ink-light);
    margin-bottom: 8px;
    margin-left: 23px;
    line-height: 1.5;
    font-style: italic;
  }

  textarea {
    width: 100%;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink);
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 12px 14px;
    resize: vertical;
    min-height: 90px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(45,106,79,0.08);
  }

  textarea.tall { min-height: 110px; }

  textarea::placeholder { color: #C5BFB9; }

  /* ── DIVIDER ── */
  .section-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 28px 0;
  }

  /* ── CALLOUT ── */
  .callout {
    background: var(--accent-light);
    border-left: 3px solid var(--accent);
    border-radius: 0 8px 8px 0;
    padding: 12px 16px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink);
    margin: 16px 0 24px;
  }

  .callout.amber {
    background: var(--amber-light);
    border-color: var(--amber);
  }

  .callout.warn {
    background: var(--warn-light);
    border-color: var(--warn);
  }

  .callout strong { font-weight: 600; }

  /* ── EXAMPLE BOX ── */
  .example-box {
    background: var(--bg);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    margin: 14px 0 20px;
    font-size: 13px;
    line-height: 1.6;
  }

  .example-box .ex-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-light);
    margin-bottom: 8px;
  }

  .example-box .ex-bad { color: var(--warn); margin-bottom: 4px; }
  .example-box .ex-good { color: var(--accent); }

  /* ── ICEBERG TABLE ── */
  .iceberg-row {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 16px;
    margin-bottom: 14px;
    transition: border-color 0.2s;
  }

  .iceberg-row:focus-within { border-color: var(--accent); }

  .iceberg-level {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .level-badge {
    font-size: 18px;
  }

  .level-info { flex: 1; }

  .level-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 2px;
  }

  .level-desc {
    font-size: 11px;
    color: var(--ink-light);
    line-height: 1.4;
  }

  .iceberg-row textarea {
    min-height: 75px;
    background: var(--bg);
    border-color: transparent;
  }

  .iceberg-row textarea:focus {
    border-color: var(--accent);
    background: var(--surface);
  }

  /* ── ATTEMPT CARDS ── */
  .attempt-card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 16px;
    margin-bottom: 14px;
  }

  .attempt-card .attempt-header {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-light);
    margin-bottom: 6px;
  }

  .attempt-card .attempt-prompt {
    font-size: 17px;
    font-weight: 500;
    color: var(--ink-light);
    margin-bottom: 10px;
    font-style: italic;
  }

  .attempt-card textarea {
    background: var(--bg);
    border-color: transparent;
    min-height: 70px;
  }

  .attempt-card textarea:focus {
    background: var(--surface);
    border-color: var(--accent);
  }

  /* ── ACTIONS ── */
  .actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    padding: 11px 20px;
    border-radius: 9px;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary { background: var(--accent); color: white; }
  .btn-primary:hover { background: #235C40; transform: translateY(-1px); }

  .btn-next { background: var(--ink); color: white; }
  .btn-next:hover { background: #333; }

  .btn-ghost {
    background: transparent;
    color: var(--ink-light);
    border: 1.5px solid var(--border);
  }
  .btn-ghost:hover { border-color: var(--ink-light); color: var(--ink); }

  /* ── SAVED TOAST ── */
  .toast {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(60px);
    background: var(--ink);
    color: white;
    font-size: 13px;
    font-weight: 500;
    padding: 10px 20px;
    border-radius: 99px;
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
    z-index: 999;
    white-space: nowrap;
  }

  .toast.show { transform: translateX(-50%) translateY(0); }

  /* ── PROGRESS ── */
  .progress-bar-wrap {
    height: 3px;
    background: var(--border);
    width: 100%;
  }

  .progress-bar-fill {
    height: 100%;
    background: var(--accent);
    transition: width 0.4s ease;
  }

  /* ── COMPLETION ── */
  .completion-banner {
    background: var(--accent-light);
    border: 1.5px solid var(--accent);
    border-radius: 12px;
    padding: 20px 24px;
    text-align: center;
    display: none;
    margin-bottom: 24px;
  }

  .completion-banner.show { display: block; animation: fadeUp 0.4s ease both; }

  .completion-banner h3 {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
    color: var(--accent);
    margin-bottom: 6px;
  }

  .completion-banner p {
    font-size: 13px;
    color: var(--accent);
    line-height: 1.5;
  }

  /* ── FOOTER ── */
  .footer-note {
    text-align: center;
    font-size: 11px;
    color: var(--ink-light);
    padding: 20px 24px;
    border-top: 1px solid var(--border);
  }
</style>
</head>
